# ── Neon Postgres ─────────────────────────────────────────────
# From the Neon dashboard (or `vercel env pull` once the Neon
# integration is installed on your Vercel project). Use the pooled
# connection string.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Vercel Blob ───────────────────────────────────────────────
# Auto-provisioned when you add a Blob store to the Vercel project.
# Pull locally with `vercel env pull`.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"

# ── Web Push (VAPID) ──────────────────────────────────────────
# Generate a keypair once with: npm run gen:vapid
# The public key is exposed to the browser; keep the private key secret.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# A contact URI for the push service (mailto: or https:).
VAPID_SUBJECT="mailto:you@example.com"
