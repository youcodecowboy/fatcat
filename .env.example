# ── Neon Postgres ─────────────────────────────────────────────
# From the Neon dashboard (or `vercel env pull` once the Neon
# integration is installed on your Vercel project). Use the pooled
# connection string.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Vercel Blob ───────────────────────────────────────────────
# Auto-provisioned when you add a Blob store to the Vercel project.
# Pull locally with `vercel env pull`.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"

# ── Web Push (VAPID) ──────────────────────────────────────────
# Generate a keypair once with: npm run gen:vapid
# The public key is exposed to the browser; keep the private key secret.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# A contact URI for the push service (mailto: or https:).
VAPID_SUBJECT="mailto:you@example.com"

# ── Resend (email mailing list) ───────────────────────────────
# Send-only API key from https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxx"
# Sender address. The test sender below only delivers to your own Resend
# account email. To email anyone else, verify a domain at resend.com/domains
# and use an address on it, e.g. "FatCat <cat@yourdomain.com>".
RESEND_FROM="FatCat <onboarding@resend.dev>"
# Optional: absolute base URL for links inside emails (unsubscribe, etc).
# On Vercel this is derived automatically; set it for local testing if needed.
# NEXT_PUBLIC_APP_URL="https://fatcat-rose.vercel.app"
